# 1Money Network MCP Configuration
# Copy this file to .env and update values as needed

# Network: testnet, mainnet, or local (default: testnet)
ONEMONEY_PROTOCOL_NETWORK=testnet

# Override the network base URL (optional)
# ONEMONEY_PROTOCOL_BASE_URL=https://custom-gateway.example.com

# Request timeout in milliseconds (default: 10000)
ONEMONEY_PROTOCOL_TIMEOUT_MS=15000

# Optional JSON string of headers to include in all requests
# Only needed for custom gateways/proxies
# ONEMONEY_PROTOCOL_HEADERS={"X-API-Key": "your-api-key", "X-Custom-Header": "value"}
